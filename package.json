{
  "name": "cipherdex",
  "version": "1.0.0",
  "description": "CipherDEX - Confidential P2P Trading Protocol on Fhenix",
  "scripts": {
    "postinstall": "npx patch-package",
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "clean": "npx hardhat clean",
    "deploy:local": "npx hardhat run tasks/deploy-all.ts",
    "deploy:sepolia": "npx hardhat run tasks/deploy-all.ts --network ethSepolia",
    "deploy:arb-sepolia": "npx hardhat run tasks/deploy-all.ts --network arbSepolia"
  },
  "dependencies": {
    "@fhenixprotocol/cofhe-contracts": "^0.1.0",
    "@openzeppelin/contracts": "^5.1.0",
    "fhenix-confidential-contracts": "^0.2.0",
    "patch-package": "^8.0.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "chai": "^4.4.0",
    "cofhe-hardhat-plugin": "0.3.1",
    "cofhejs": "0.3.1",
    "dotenv": "^16.4.0",
    "ethers": "^6.13.0",
    "hardhat": "^2.22.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0"
  }
}
